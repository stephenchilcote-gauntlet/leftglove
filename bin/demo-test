#!/usr/bin/env bash
# Demo app SL test runner — starts demo app, runs sl against it
#
# Usage:
#   bin/demo-test              # full run: start app, dry-run, execute
#   bin/demo-test --use-dev    # skip app startup, assume it's running
#
# Ports (override via env vars):
#   DEMO_PORT — Demo app (default: 3000)
#
# Prerequisites:
#   - SL CLI (sl) on PATH, or SL_DIR pointing to shiftlefter repo
#   - Node.js for demo app

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"
LG_DIR="$(dirname "$SCRIPT_DIR")"
SL_PROJECT="$LG_DIR/leftglove/demo-app/sl-project"
SL_DIR="${SL_DIR:-$(dirname "$LG_DIR")/shiftlefter}"

DEMO_PORT="${DEMO_PORT:-3000}"
LABEL="demo-test"

USE_DEV=false
if [[ "${1:-}" == "--use-dev" ]]; then
  USE_DEV=true
fi

# Resolve sl command
if command -v sl &>/dev/null; then
  SL_CMD="sl"
elif [[ -x "$SL_DIR/bin/sl" ]]; then
  SL_CMD="$SL_DIR/bin/sl"
else
  echo "[$LABEL] ERROR: sl not found on PATH or at $SL_DIR/bin/sl"
  echo "[$LABEL] Set SL_DIR to the shiftlefter repo root."
  exit 1
fi

register_cleanup "$LABEL"

if [[ "$USE_DEV" == "true" ]]; then
  echo "[demo-test] --use-dev: assuming demo app already running on port $DEMO_PORT"
else
  # --- Start demo app ---
  echo "[demo-test] Starting demo app on port $DEMO_PORT..."
  cd "$LG_DIR/leftglove/demo-app"
  PORT="$DEMO_PORT" node server.js &
  PIDS+=($!)
  cd "$LG_DIR"
fi

# --- Wait for demo app ---
wait_for "$LABEL" "demo app" "http://localhost:$DEMO_PORT/healthz"
echo "[$LABEL] Demo app healthy at http://localhost:$DEMO_PORT"
echo ""

# --- Phase 1: Dry run each feature ---
cd "$SL_PROJECT"
for feature in features/*.feature; do
  fname="$(basename "$feature")"
  echo "[demo-test] Phase 1: $SL_CMD run --dry-run $feature"
  if $SL_CMD run --dry-run "$feature"; then
    echo "[demo-test] PASS: dry-run $fname"
  else
    echo "[demo-test] FAIL: dry-run $fname (exit $?)"
    exit 1
  fi
  echo ""
done

# --- Phase 2: Execute each feature ---
for feature in features/*.feature; do
  fname="$(basename "$feature")"
  echo "[demo-test] Phase 2: $SL_CMD run $feature"
  if $SL_CMD run "$feature"; then
    echo "[demo-test] PASS: $fname"
  else
    echo "[demo-test] FAIL: $fname (exit $?)"
    exit 1
  fi
  echo ""
done
echo ""

echo "[demo-test] All tests passed."
