[2.645, "o", "  \u001b[35mScenario:\u001b[0m Donor can enable monthly recurring donation\r\n"]
[2.665, "o", "    \u001b[36mGiven\u001b[0m :test opens the browser to 'http://localhost:3000/fundraiser'\r\n"]
