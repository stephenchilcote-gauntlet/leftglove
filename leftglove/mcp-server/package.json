{
  "name": "leftglove",
  "version": "0.1.0",
  "description": "MCP server that makes any website usable by AI agents — filters 90% of DOM noise, returns structured element inventory with stable locators",
  "type": "module",
  "bin": {
    "leftglove": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp src/sieve/sieve.js dist/sieve/sieve.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "npx tsx --test src/**/*.test.ts",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-automation",
    "ai-agents",
    "browser",
    "playwright",
    "sieve",
    "dom",
    "scraping"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stephenchilcote-gauntlet/leftglove"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.52.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
