;; Intent region: Login
;; The login page — form fields, submit button, status message, navigation.

{:intent "Login"
 :description "Login page with email/password form"
 :elements
 {:email-input     {:desc "Email address field"
                    :type :typable
                    :bindings {:web {:css "[data-testid='email-input']"}}}
  :password-input  {:desc "Password field"
                    :type :typable
                    :bindings {:web {:css "[data-testid='password-input']"}}}
  :login-submit    {:desc "Sign In button"
                    :type :clickable
                    :bindings {:web {:css "[data-testid='login-submit']"}}}
  :status-msg      {:desc "Status/error message display"
                    :type :readable
                    :bindings {:web {:css "[data-testid='status-msg']"}}}
  :nav-home        {:desc "Home nav link"
                    :type :clickable
                    :bindings {:web {:css "[data-testid='nav-home']"}}}
  :nav-login       {:desc "Login nav link"
                    :type :clickable
                    :bindings {:web {:css "[data-testid='nav-login']"}}}
  :forgot-password {:desc "Forgot password link"
                    :type :clickable
                    :bindings {:web {:css "[data-testid='forgot-password']"}}}}}
