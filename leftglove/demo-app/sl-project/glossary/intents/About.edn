;; Intent region: About
;; The about page — static content, feature list, team section.

{:intent "About"
 :description "About page with app description and team info"
 :elements
 {:about-heading     {:desc "About page heading"
                      :type :readable
                      :bindings {:web {:testid "about-heading"}}}
  :about-description {:desc "App description paragraph"
                      :type :readable
                      :bindings {:web {:testid "about-description"}}}
  :features-heading  {:desc "Features section heading"
                      :type :readable
                      :bindings {:web {:testid "features-heading"}}}
  :feature-list      {:desc "Feature bullet list"
                      :type :readable
                      :bindings {:web {:testid "feature-list"}}}
  :feature-auth      {:desc "Secure authentication feature item"
                      :type :readable
                      :bindings {:web {:testid "feature-auth"}}}
  :feature-dashboard {:desc "User dashboard feature item"
                      :type :readable
                      :bindings {:web {:testid "feature-dashboard"}}}
  :feature-responsive {:desc "Responsive design feature item"
                       :type :readable
                       :bindings {:web {:testid "feature-responsive"}}}
  :team-heading      {:desc "Team section heading"
                      :type :readable
                      :bindings {:web {:testid "team-heading"}}}
  :team-description  {:desc "Team description"
