<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Login to DemoApp">
  <title>Login — DemoApp</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <!-- CHROME: nav bar -->
  <nav aria-label="Main Navigation">
    <a href="/" data-testid="nav-home">DemoApp</a>
    <a href="/login" data-testid="nav-login">Login</a>
  </nav>

  <!-- NOISE: empty wrapper divs (sieve should filter) -->
  <div class="wrapper">
    <div class="container">

      <main>
        <!-- READABLE: page heading -->
        <h1 id="login-heading">Sign In</h1>

        <!-- READABLE: status/error message -->
        <% if (message) { %>
        <p role="status" aria-live="polite" id="status-msg" data-testid="status-msg" class="error">
          <%= message %>
        </p>
        <% } else { %>
        <p role="status" aria-live="polite" id="status-msg" data-testid="status-msg">
          Enter your credentials to continue.
        </p>
        <% } %>

        <!-- NOISE: decorative spacer -->
        <div class="spacer"></div>

        <!-- FORM: login form -->
        <form method="POST" action="/login" id="login-form" aria-label="Login">

          <!-- TYPABLE: email input with label -->
          <div class="form-group">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email"
                   placeholder="you@example.com"
                   data-testid="email-input"
                   required>
          </div>

          <!-- TYPABLE: password input with label -->
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password"
                   placeholder="Enter password"
                   data-testid="password-input"
                   required>
          </div>

          <!-- === REMEMBER ME INSERTION POINT === -->

          <!-- CLICKABLE: submit button -->
          <button type="submit" id="login-btn" data-testid="login-submit">
            Sign In
          </button>
        </form>

        <!-- NOISE: spacer -->
        <div class="spacer"></div>

        <!-- CLICKABLE: forgot password link -->
        <a href="/forgot-password" id="forgot-password" data-testid="forgot-password">
          Forgot your password?
        </a>

      </main>

    </div>
  </div>

  <!-- CHROME: footer -->
  <footer>
    <p>&copy; 2026 DemoApp. All rights reserved.</p>
  </footer>

  <!-- NOISE: hidden element (sieve should filter) -->
  <div style="display: none;" aria-hidden="true">Hidden tracking pixel placeholder</div>

</body>
</html>
