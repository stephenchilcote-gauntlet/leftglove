<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="About DemoApp">
  <title>About — DemoApp</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <!-- CHROME: nav bar (same as login, but with About link) -->
  <nav aria-label="Main Navigation">
    <a href="/" data-testid="nav-home">DemoApp</a>
    <a href="/login" data-testid="nav-login">Login</a>
    <a href="/about" data-testid="nav-about">About</a>
  </nav>

  <div class="wrapper">
    <div class="container">

      <main>
        <!-- READABLE: page heading -->
        <h1 id="about-heading" data-testid="about-heading">About DemoApp</h1>

        <!-- READABLE: description paragraph -->
        <p id="about-description" data-testid="about-description">
          DemoApp is a sample application used for testing web element
          cataloging and visual regression tools.
        </p>

        <!-- READABLE: feature list -->
        <h2 id="features-heading" data-testid="features-heading">Features</h2>
        <ul id="feature-list" data-testid="feature-list">
          <li data-testid="feature-auth">Secure authentication</li>
          <li data-testid="feature-dashboard">User dashboard</li>
          <li data-testid="feature-responsive">Responsive design</li>
        </ul>

        <!-- READABLE: team section -->
        <h2 id="team-heading" data-testid="team-heading">Our Team</h2>
        <p id="team-description" data-testid="team-description">
          Built by the LeftGlove project for exploration and testing.
        </p>

        <!-- CLICKABLE: CTA button -->
        <a href="/login" id="cta-login" data-testid="cta-login" class="cta-button">
          Get Started
        </a>

        <!-- CLICKABLE: contact link -->
        <a href="mailto:hello@example.com" id="contact-link" data-testid="contact-link">
          Contact us
        </a>

      </main>

    </div>
  </div>

  <!-- CHROME: footer -->
  <footer>
    <p>&copy; 2026 DemoApp. All rights reserved.</p>
  </footer>

</body>
</html>
