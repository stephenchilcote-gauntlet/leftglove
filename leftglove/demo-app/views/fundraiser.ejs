<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Support Open Greenways for 2025 — CrowdFund</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#16A34A',
            'green-soft': '#EAF8EE',
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: -apple-system, 'Segoe UI', system-ui, sans-serif; background: #F7FAF7; color: #111827; }
    .text-muted { color: #6B7280; }
  </style>
</head>
<body class="min-h-full flex flex-col antialiased">

  <!-- Header -->
  <header class="sticky top-0 z-50 border-b bg-white" data-testid="site-header">
    <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4">
      <a href="/" class="flex items-center gap-2" data-testid="logo-link">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path d="M14 25.5C14 25.5 3.5 18 3.5 10.5C3.5 6.5 6.5 3.5 10 3.5C12 3.5 13.5 4.5 14 5.5C14.5 4.5 16 3.5 18 3.5C21.5 3.5 24.5 6.5 24.5 10.5C24.5 18 14 25.5 14 25.5Z" fill="#16A34A" stroke="#16A34A" stroke-width="1.5"/>
        </svg>
        <span class="text-xl font-bold text-primary">CrowdFund</span>
      </a>
      <nav class="flex items-center gap-5 text-[15px]">
        <a href="/" class="font-semibold text-gray-900 relative after:absolute after:-bottom-[1.125rem] after:left-0 after:right-0 after:h-0.5 after:bg-primary after:rounded-full" data-testid="nav-community">Community</a>
        <a href="/" class="text-gray-500 hover:text-gray-900 hidden sm:inline" data-testid="nav-analytics">Analytics</a>
        <a href="/" class="rounded-full bg-black px-4 py-1.5 text-sm font-medium text-white hover:bg-black/85" data-testid="nav-start">Start a CrowdFund</a>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">

    <!-- Title -->
    <div class="mb-5">
      <span class="inline-flex items-center rounded-full bg-green-soft px-2.5 py-0.5 text-xs font-medium text-primary mb-2" data-testid="badge-fundraiser">Fundraiser</span>
      <h1 class="text-2xl font-bold tracking-tight md:text-3xl leading-tight" data-testid="fundraiser-title">Support Open Greenways for 2025</h1>
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <!-- Left column: hero + story + updates + comments -->
      <div class="order-2 lg:order-1 lg:col-span-7">
        <img src="/images/hero-placeholder.jpg" alt="Open greenways initiative" class="w-full h-56 md:h-72 object-cover rounded-2xl mb-6 ring-1 ring-gray-900/10" data-testid="hero-image" />

        <p class="text-gray-500 leading-relaxed mb-6 pl-4 border-l-2 border-primary/30" data-testid="description">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Help us raise $150,000 to keep this project free and accessible for everyone through 2025.
        </p>

        <hr class="mb-8 border-gray-200" />

        <!-- Updates section -->
        <div class="mb-2">
          <h2 class="text-lg font-bold" data-testid="section-updates">Updates</h2>
          <p class="text-sm text-gray-500">5 updates from the organizer</p>
        </div>

        <div class="space-y-4 mt-4 mb-8" data-testid="updates-list">
          <div class="relative pl-6 border-l-2 border-primary/20 pb-4">
            <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-full bg-primary"></div>
            <p class="text-xs text-gray-500 mb-1">March 12, 2025</p>
            <h3 class="text-sm font-semibold" data-testid="update-title-1">Spring fundraising push</h3>
            <p class="text-sm text-gray-500 mt-1">Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. With $62,575 still to raise, we need your help.</p>
          </div>
          <div class="relative pl-6 border-l-2 border-primary/20 pb-4">
            <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-full bg-primary"></div>
            <p class="text-xs text-gray-500 mb-1">March 5, 2025</p>
            <h3 class="text-sm font-semibold" data-testid="update-title-2">Multilingual support launched</h3>
            <p class="text-sm text-gray-500 mt-1">Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.</p>
          </div>
          <div class="relative pl-6 border-l-2 border-primary/20 pb-4">
            <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-full bg-primary"></div>
            <p class="text-xs text-gray-500 mb-1">January 15, 2025</p>
            <h3 class="text-sm font-semibold" data-testid="update-title-3">We hit 50%! Infrastructure upgraded</h3>
            <p class="text-sm text-gray-500 mt-1">Ut enim ad minima veniam, quis nostrum exercitationem ullam corporis suscipit laboriosam, nisi ut aliquid ex ea commodi consequatur.</p>
          </div>
        </div>

        <hr class="my-8 border-gray-200" />

        <!-- Supporter Comments -->
        <div class="mb-2">
          <h2 class="text-lg font-bold" data-testid="section-comments">Supporter Comments</h2>
          <p class="text-sm text-gray-500">See what supporters are saying</p>
        </div>

        <div class="space-y-4 mt-4" data-testid="comments-list">
          <div class="rounded-xl bg-white ring-1 ring-gray-900/5 p-4" data-testid="comment-1">
            <p class="text-sm text-gray-700 italic">"Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore."</p>
            <div class="mt-2 flex items-center gap-2 text-xs text-gray-500">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-primary/10 text-primary text-[10px] font-bold">A</span>
              <span class="font-medium text-gray-900">Alex T.</span> &middot; $50 &middot; Mar 10
            </div>
          </div>
          <div class="rounded-xl bg-white ring-1 ring-gray-900/5 p-4" data-testid="comment-2">
            <p class="text-sm text-gray-700 italic">"Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip."</p>
            <div class="mt-2 flex items-center gap-2 text-xs text-gray-500">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-primary/10 text-primary text-[10px] font-bold">R</span>
              <span class="font-medium text-gray-900">River K.</span> &middot; $100 &middot; Mar 8
            </div>
          </div>
          <div class="rounded-xl bg-white ring-1 ring-gray-900/5 p-4" data-testid="comment-3">
            <p class="text-sm text-gray-700 italic">"Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur."</p>
            <div class="mt-2 flex items-center gap-2 text-xs text-gray-500">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-primary/10 text-primary text-[10px] font-bold">J</span>
              <span class="font-medium text-gray-900">The Johnson Family</span> &middot; $150 &middot; Feb 28
            </div>
          </div>
        </div>

        <hr class="my-8 border-gray-200" />

        <!-- More campaigns -->
        <div class="mb-2">
          <h2 class="text-lg font-bold" data-testid="section-more-campaigns">More campaigns in this community</h2>
          <p class="text-sm text-gray-500">Greenways Initiative</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 mt-4">
          <a href="/" class="group rounded-2xl bg-white ring-1 ring-gray-900/5 overflow-hidden hover:shadow-md transition-shadow" data-testid="campaign-card-1">
            <img src="/images/card-placeholder-1.jpg" alt="" class="w-full h-32 object-cover" />
            <div class="p-4">
              <h3 class="text-sm font-semibold group-hover:text-primary transition-colors">Equip Neighborhood Supply Kits</h3>
              <div class="mt-2 h-1.5 w-full rounded-full bg-green-soft overflow-hidden">
                <div class="h-full rounded-full bg-primary" style="width: 42%"></div>
              </div>
              <div class="mt-2 flex gap-4 text-xs text-gray-500">
                <span><strong class="text-gray-900">42%</strong> funded</span>
                <span><strong class="text-gray-900">342</strong> donors</span>
              </div>
            </div>
          </a>
          <a href="/" class="group rounded-2xl bg-white ring-1 ring-gray-900/5 overflow-hidden hover:shadow-md transition-shadow" data-testid="campaign-card-2">
            <img src="/images/card-placeholder-2.jpg" alt="" class="w-full h-32 object-cover" />
            <div class="p-4">
              <h3 class="text-sm font-semibold group-hover:text-primary transition-colors">Expand Rural Trail Coverage</h3>
              <div class="mt-2 h-1.5 w-full rounded-full bg-green-soft overflow-hidden">
                <div class="h-full rounded-full bg-primary" style="width: 25%"></div>
              </div>
              <div class="mt-2 flex gap-4 text-xs text-gray-500">
                <span><strong class="text-gray-900">25%</strong> funded</span>
                <span><strong class="text-gray-900">198</strong> donors</span>
              </div>
            </div>
          </a>
        </div>
      </div>

      <!-- Right column: sticky donation sidebar -->
      <div class="order-1 lg:order-2 lg:col-span-5">
        <div class="sticky top-24 rounded-2xl bg-white ring-1 ring-gray-900/10 p-6 space-y-5">

          <!-- Progress card -->
          <div class="mb-5" data-testid="progress-card">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-4xl font-bold text-primary tracking-tight" data-testid="amount-raised">$87,425</span>
              <span class="text-gray-500 text-sm">raised of $150,000 goal</span>
            </div>
            <div class="mt-3 relative h-2.5">
              <div class="absolute inset-0 rounded-full overflow-hidden bg-green-soft">
                <div class="h-full rounded-full bg-primary transition-all" style="width: 58%" data-testid="progress-bar"></div>
              </div>
              <div class="absolute top-0 h-full w-px bg-gray-900/20 pointer-events-none" style="left: 75%"></div>
            </div>
            <div class="mt-2.5 flex gap-5 text-sm text-gray-500">
              <span><strong class="text-gray-900 font-semibold" data-testid="donor-count">1,247</strong> donors</span>
              <span><strong class="text-gray-900 font-semibold" data-testid="percent-funded">58%</strong> funded</span>
            </div>
          </div>

          <!-- Pace projection -->
          <p class="text-xs text-gray-500 -mt-2 pb-1" data-testid="pace-projection">
            At current pace, <span class="font-medium text-gray-900">goal reached in ~120 days</span> · 476 $/day avg
          </p>

          <!-- Latest donor -->
          <p class="text-xs text-gray-500 flex items-center gap-1.5 -mt-1" data-testid="latest-donor">
            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-primary/10 text-primary text-[10px] font-bold shrink-0">C</span>
            <span><span class="font-medium text-gray-900">Casey</span> donated <span class="font-medium text-primary">$75</span></span>
          </p>

          <!-- Donate button (opens sheet) -->
          <button onclick="document.getElementById('donate-sheet').classList.remove('translate-x-full')" class="w-full rounded-full bg-primary text-white text-base font-semibold h-12 hover:bg-primary/90 transition-colors" data-testid="donate-button">
            Donate Now
          </button>

          <% if (locals.showRecurring) { %>
          <!-- Recurring donation toggle (added by agent) -->
          <div class="rounded-xl bg-green-50 p-4 ring-1 ring-green-200" data-testid="recurring-donation">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary" data-testid="recurring-checkbox" />
              <div>
                <span class="text-sm font-medium text-gray-900">Make it monthly</span>
                <p class="text-xs text-gray-500 mt-0.5">Set up a recurring monthly donation</p>
              </div>
            </label>
          </div>
          <% } %>

          <!-- Action buttons -->
          <div class="flex gap-2">
            <button class="flex-1 rounded-full border border-gray-300 px-6 py-2.5 text-sm font-medium hover:border-primary/50 transition-colors" data-testid="follow-button">
              Follow
            </button>
            <button class="flex-1 rounded-full bg-gray-100 px-6 py-2.5 text-sm font-medium hover:bg-gray-200 transition-colors" data-testid="share-button">
              <span class="inline-flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                Share
              </span>
            </button>
          </div>

          <hr class="border-gray-200" />

          <!-- Organizer -->
          <a href="/" class="block group" data-testid="organizer-card">
            <div class="flex items-center gap-3">
              <img src="/avatars/placeholder.jpg" alt="" class="h-10 w-10 rounded-full object-cover ring-1 ring-gray-900/5" data-testid="organizer-avatar" />
              <div>
                <p class="text-xs text-gray-500">Organized by</p>
                <p class="text-sm font-semibold group-hover:text-primary transition-colors" data-testid="organizer-name">Jordan Reeves</p>
                <p class="text-xs text-gray-500">Community Organizer</p>
              </div>
            </div>
          </a>

          <!-- Community -->
          <a href="/" class="block group" data-testid="community-card">
            <div class="rounded-2xl bg-gray-50 py-3 px-4 transition-shadow hover:shadow-sm">
              <p class="text-xs text-gray-500">Part of community</p>
              <p class="text-sm font-semibold group-hover:text-primary transition-colors" data-testid="community-name">Greenways Initiative</p>
              <p class="text-xs text-gray-500">2,847 members</p>
            </div>
          </a>
        </div>
      </div>

    </div>
  </main>

  <!-- Footer -->
  <footer>
    <div class="bg-[#024430] text-white" data-testid="footer-hero">
      <div class="mx-auto max-w-5xl px-4 py-12 text-center">
        <h2 class="text-2xl font-bold md:text-3xl">Every donation makes a difference</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm text-white/80">Together, we can make a difference and help communities grow, connect, and thrive.</p>
      </div>
    </div>
    <div class="border-t bg-white" data-testid="footer-links">
      <div class="mx-auto max-w-5xl px-4 py-10">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          <div>
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-900">Fundraise for</h3>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/" class="hover:text-gray-900 transition-colors">Medical</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Education</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Emergency</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Nonprofit</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Community</a></li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-900">Learn more</h3>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/" class="hover:text-gray-900 transition-colors">How It Works</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Success Stories</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Pricing</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Supported Countries</a></li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-900">Resources</h3>
            <ul class="space-y-2 text-sm text-gray-500">
              <li><a href="/" class="hover:text-gray-900 transition-colors">Help Center</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Blog</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Careers</a></li>
              <li><a href="/" class="hover:text-gray-900 transition-colors">Press Center</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="border-t bg-white" data-testid="footer-copyright">
      <div class="mx-auto max-w-5xl px-4 py-4 text-center text-xs text-gray-500">
        &copy; 2025 CrowdFund &mdash; Community Fundraising Platform. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- Donate Sheet (slide-out panel) -->
  <div id="donate-overlay" class="fixed inset-0 z-[60] bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300" onclick="closeDonateSheet()"></div>
  <div id="donate-sheet" class="fixed top-0 right-0 z-[70] h-full w-full max-w-md bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-out overflow-y-auto" data-testid="donate-sheet">
    <div class="p-6">
      <!-- Sheet header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-lg font-bold" data-testid="sheet-title">Make a Donation</h2>
          <p class="text-sm text-gray-500">Support this fundraiser.</p>
        </div>
        <button onclick="closeDonateSheet()" class="h-8 w-8 rounded-full hover:bg-gray-100 flex items-center justify-center" data-testid="sheet-close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Amount selection -->
      <div class="space-y-2 mb-5">
        <label class="text-sm font-medium text-gray-900" data-testid="amount-label">Amount</label>
        <div class="grid grid-cols-4 gap-2" data-testid="amount-presets">
          <button onclick="selectAmount(10)" class="rounded-lg border-2 border-gray-200 py-2 text-sm font-medium hover:border-primary/50 transition-colors" data-testid="preset-10">$10</button>
          <button onclick="selectAmount(25)" class="rounded-lg border-2 border-primary bg-primary/10 text-primary py-2 text-sm font-medium" data-testid="preset-25">$25</button>
          <button onclick="selectAmount(50)" class="rounded-lg border-2 border-gray-200 py-2 text-sm font-medium hover:border-primary/50 transition-colors" data-testid="preset-50">$50</button>
          <button onclick="selectAmount(100)" class="rounded-lg border-2 border-gray-200 py-2 text-sm font-medium hover:border-primary/50 transition-colors" data-testid="preset-100">$100</button>
        </div>
        <input type="number" id="pledge-amount" min="1" step="1" value="25" placeholder="Or enter custom amount" class="h-10 w-full rounded-lg border border-gray-300 bg-transparent px-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" data-testid="amount-input" />
      </div>

      <!-- Impact preview -->
      <p class="text-xs text-gray-500 bg-gray-50 px-3 py-2.5 rounded-lg mb-5" data-testid="impact-preview">
        Your donation would bring this campaign to <strong class="text-gray-900">45.2% funded</strong> and add you to <strong class="text-gray-900">1,542 donors</strong>.
      </p>

      <!-- Name -->
      <div class="space-y-2 mb-4">
        <label for="pledge-name" class="text-sm font-medium text-gray-900" data-testid="name-label">Your Name</label>
        <input type="text" id="pledge-name" placeholder="Anonymous" class="h-10 w-full rounded-lg border border-gray-300 bg-transparent px-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary" data-testid="name-input" />
      </div>

      <!-- Comment -->
      <div class="space-y-2 mb-6">
        <label for="pledge-comment" class="text-sm font-medium text-gray-900" data-testid="comment-label">Comment (optional)</label>
        <textarea id="pledge-comment" placeholder="Leave a message of support..." rows="3" class="w-full rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary resize-none" data-testid="comment-input"></textarea>
      </div>

      <!-- Submit -->
      <button class="w-full rounded-full bg-primary text-white text-base font-semibold h-12 hover:bg-primary/90 transition-colors mb-3" data-testid="pledge-submit">
        Donate
      </button>
      <button onclick="closeDonateSheet()" class="w-full rounded-full border border-gray-300 text-sm font-medium h-12 hover:bg-gray-50 transition-colors" data-testid="pledge-cancel">
        Cancel
      </button>
    </div>
  </div>

  <script>
    function closeDonateSheet() {
      document.getElementById('donate-sheet').classList.add('translate-x-full');
      document.getElementById('donate-overlay').classList.add('opacity-0', 'pointer-events-none');
    }
    // When sheet opens, show overlay
    const donateBtn = document.querySelector('[data-testid="donate-button"]');
    donateBtn.addEventListener('click', () => {
      const overlay = document.getElementById('donate-overlay');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
    });
    function selectAmount(n) {
      document.getElementById('pledge-amount').value = n;
      document.querySelectorAll('[data-testid^="preset-"]').forEach(btn => {
        btn.className = btn.className.replace(/border-primary bg-primary\/10 text-primary/g, 'border-gray-200');
      });
      const sel = document.querySelector(`[data-testid="preset-${n}"]`);
      if (sel) sel.className = sel.className.replace('border-gray-200', 'border-primary bg-primary/10 text-primary');
    }
  </script>

</body>
</html>
