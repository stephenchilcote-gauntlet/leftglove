<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — DemoApp</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <nav aria-label="Main Navigation">
    <a href="/" data-testid="nav-home">DemoApp</a>
    <a href="/dashboard" data-testid="nav-dashboard">Dashboard</a>
    <a href="/logout" data-testid="nav-logout">Logout</a>
  </nav>

  <div class="wrapper">
    <div class="container">
      <main>
        <h1 id="dashboard-heading">Dashboard</h1>
        <p id="welcome-msg" data-testid="welcome-msg">
          Welcome, <%= user.name %>!
        </p>
        <section id="content" data-testid="dashboard-content">
          <p>You are logged in as <strong><%= user.email %></strong>.</p>
        </section>
      </main>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 DemoApp. All rights reserved.</p>
    <a href="/help" target="_blank" data-testid="help-link">Open Help in New Tab</a>
  </footer>

  <script>
    localStorage.setItem('theme', 'light');
    localStorage.setItem('lastLogin', new Date().toISOString());
  </script>
</body>
</html>
